# Environment variables
ANTHROPIC_API_KEY=your_api_key_here

# ZEsarUX ZRCP connection
ZESARUX_HOST=localhost
ZESARUX_PORT=10000

# Optional settings
# ZESARUX_TIMEOUT=30000
# ZESARUX_RETRY_ATTEMPTS=3
# LOG_LEVEL=info

# Auto-launch ZEsarUX when it isn't already running (opt-in)
# ZESARUX_AUTOLAUNCH=true
# ZESARUX_PATH=/Applications/ZEsarUX.app/Contents/MacOS/zesarux
# ZESARUX_ARGS=--vo null --ao null   # e.g. headless on a host without a display
# ZESARUX_LAUNCH_TIMEOUT=20000
